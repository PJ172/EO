{
  "name": "eoffice",
  "version": "1.0.0",
  "description": "eOffice - Enterprise Office Management System",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "patch-package",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev:web": "turbo run dev --filter=@eoffice/web",
    "dev:api": "turbo run dev --filter=@eoffice/api",
    "db:generate": "turbo run db:generate --filter=@eoffice/api",
    "db:push": "turbo run db:push --filter=@eoffice/api",
    "db:migrate": "turbo run db:migrate --filter=@eoffice/api",
    "db:studio": "turbo run db:studio --filter=@eoffice/api"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "patch-package": "^8.0.1",
    "turbo": "^2.3.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.0.0",
  "dependencies": {
    "@xyflow/react": "^12.10.1",
    "elkjs": "^0.11.1"
  }
}
