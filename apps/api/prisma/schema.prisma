  note        String?                       // Ghi chú
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now())      @map("created_at")
  updatedById String?  @map("updated_by_id")
  updatedAt   DateTime @updatedAt           @map("updated_at")

  createdBy   User?    @relation("CategoryCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?    @relation("CategoryUpdatedBy", fields: [updatedById], references: [id])

  @@index([status])
  @@index([type])
  @@map("categories")
}

model Location {
  id          String   @id @default(uuid())
  code        String   @unique              // prefix(2) + seq(5): NM00001, TD00001...
  prefix      String   @db.VarChar(2)       // 2-char prefix: NM, TD, DL, VP...
  name        String                        // Tên vị trí
  detail      String?                       // Chi tiết vị trí
  status      String   @default("ACTIVE")  // ACTIVE | INACTIVE
  description String?                       // Diễn giải
  note        String?                       // Ghi chú
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now())      @map("created_at")
  updatedById String?  @map("updated_by_id")
  updatedAt   DateTime @updatedAt           @map("updated_at")

  createdBy   User?    @relation("LocationCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?    @relation("LocationUpdatedBy", fields: [updatedById], references: [id])

  @@index([status])
  @@index([prefix])
  @@map("locations")
}
