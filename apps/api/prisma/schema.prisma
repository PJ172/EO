model Software {
  id            String               @id @default(uuid())
  name          String                                      // Windows 11 Pro, Office 365, etc.
  vendor        String?                                     // Microsoft, Autodesk, etc.
  version       String?
  licenseType   SoftwareLicenseType  @default(FREE) @map("license_type")
  licenseKey    String?              @map("license_key")
  maxInstalls   Int?                 @map("max_installs")   // null = unlimited
  purchaseDate  DateTime?            @map("purchase_date")
  expiryDate    DateTime?            @map("expiry_date")
  cost          Int?                                        // VND
  note          String?
  status        String               @default("ACTIVE")    // ACTIVE | INACTIVE | EXPIRED
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  installations SoftwareInstallation[]

  @@index([licenseType])
  @@index([status])
  @@map("software")
}

model SoftwareInstallation {
  id            String    @id @default(uuid())
  softwareId    String    @map("software_id")
  assetId       String    @map("asset_id")
  installedDate DateTime  @default(now()) @map("installed_date")
  removedDate   DateTime? @map("removed_date")
  installedBy   String?   @map("installed_by")           // ADMIN | USER | AGENT
  isAuthorized  Boolean   @default(true) @map("is_authorized")
  detectedBy    String?   @map("detected_by")            // MANUAL | AGENT | SCAN
  version       String?
  note          String?
  createdAt     DateTime  @default(now()) @map("created_at")
  software      Software  @relation(fields: [softwareId], references: [id], onDelete: Cascade)
  asset         ITAsset   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([softwareId])
  @@index([assetId])
  @@index([isAuthorized])
  @@map("software_installations")
}

model EndpointScan {
  id           String   @id @default(uuid())
  assetId      String   @map("asset_id")
  scannedAt    DateTime @default(now()) @map("scanned_at")
  hostname     String?
  osVersion    String?  @map("os_version")
  cpuInfo      String?  @map("cpu_info")
  ramTotal     Int?     @map("ram_total")             // MB
  diskTotal    Int?     @map("disk_total")            // GB
  diskFree     Int?     @map("disk_free")             // GB
  ipAddress    String?  @map("ip_address")
  macAddress   String?  @map("mac_address")
  uptime       Int?                                   // minutes
  healthScore  Int?     @map("health_score")          // 0-100
  softwareList Json?    @map("software_list")         // snapshot [{name, version, installDate}]
  asset        ITAsset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([scannedAt])
  @@map("endpoint_scans")
}

