  dessert   String?
  price     Int         @default(0)
  note      String?
  createdAt DateTime    @default(now()) @map("created_at")
  session   MealSession @relation(fields: [sessionId], references: [id])

  @@unique([date, sessionId])
  @@map("meal_menus")
}

model AssetCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  icon        String?
  createdAt   DateTime  @default(now()) @map("created_at")
  assets      ITAsset[]

  @@map("asset_categories")
}

model ITAsset {
  id              String             @id @default(uuid())
  code            String             @unique
  name            String
  categoryId      String             @map("category_id")
  assetType       String?            @map("asset_type")  // SERVER, LAPTOP, DESKTOP, MONITOR, PRINTER, ROUTER, SWITCH, ACCESS_POINT, CAMERA, DVR_NVR, OTHER
  brand           String?
  model           String?
  serialNumber    String?            @unique @map("serial_number")
  purchaseDate    DateTime?          @map("purchase_date")
  purchasePrice   Int?               @map("purchase_price")
  warrantyEndDate DateTime?          @map("warranty_end_date")
  status          AssetStatus        @default(AVAILABLE)
  condition       AssetCondition     @default(GOOD)
  location        String?
  ipAddress       String?            @map("ip_address")
  macAddress      String?            @map("mac_address")
  hostname        String?
  specifications  Json?
  note            String?
  assignedToId    String?            @map("assigned_to_id")
  departmentId    String?            @map("department_id")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  deletedAt       DateTime?          @map("deleted_at")
  deletedBatchId  String?            @map("deleted_batch_id")
  deletedById     String?            @map("deleted_by_id")
  assignments         AssetAssignment[]
  maintenances        AssetMaintenance[]
  softwareInstalls    SoftwareInstallation[]
  endpointScans       EndpointScan[]
  assignedTo      Employee?          @relation(fields: [assignedToId], references: [id])
  category        AssetCategory      @relation(fields: [categoryId], references: [id])
  department      Department?        @relation(fields: [departmentId], references: [id])
  tickets         Ticket[]

  @@index([categoryId])
  @@index([status])
  @@index([assignedToId])
  @@index([assetType])
  @@index([deletedAt])
  @@index([deletedBatchId])
  @@map("it_assets")
}

model AssetAssignment {
  id                String          @id @default(uuid())
  assetId           String          @map("asset_id")
  employeeId        String          @map("employee_id")
  assignedDate      DateTime        @default(now()) @map("assigned_date")
  returnedDate      DateTime?       @map("returned_date")
  conditionOnAssign AssetCondition  @default(GOOD) @map("condition_on_assign")
  conditionOnReturn AssetCondition? @map("condition_on_return")
  note              String?
  assignedById      String?         @map("assigned_by_id")
  asset             ITAsset         @relation(fields: [assetId], references: [id])
  employee          Employee        @relation(fields: [employeeId], references: [id])

  @@index([assetId])
  @@index([employeeId])
  @@map("asset_assignments")
}

model AssetMaintenance {
  id            String            @id @default(uuid())
  assetId       String            @map("asset_id")
  type          MaintenanceType
  scheduledDate DateTime          @map("scheduled_date")
  completedDate DateTime?         @map("completed_date")
  cost          Int?
  vendor        String?
  description   String?
  status        MaintenanceStatus @default(SCHEDULED)
  createdAt     DateTime          @default(now()) @map("created_at")
  asset         ITAsset           @relation(fields: [assetId], references: [id])

  @@index([assetId])
  @@map("asset_maintenances")
}

model TicketCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  icon        String?
  slaHours    Int      @default(24) @map("sla_hours")
  createdAt   DateTime @default(now()) @map("created_at")
  tickets     Ticket[]

  @@map("ticket_categories")
}

model Ticket {
  id                 String                @id @default(uuid())
  code               String                @unique
  title              String
  description        String
  categoryId         String                @map("category_id")
  priority           TicketPriority        @default(MEDIUM)
  status             TicketStatus          @default(DRAFT)
  requesterId        String                @map("requester_id")
  assigneeId         String?               @map("assignee_id")
  resolvedAt         DateTime?             @map("resolved_at")
  closedAt           DateTime?             @map("closed_at")
  slaDeadline        DateTime?             @map("sla_deadline")
  resolution         String?
  rating             Int?
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  assetId            String?               @map("asset_id")
  currentStepOrder   Int                   @default(0) @map("current_step_order")
  deletedAt          DateTime?             @map("deleted_at")
  deletedBatchId     String?               @map("deleted_batch_id")
  deletedById        String?               @map("deleted_by_id")
  isApproved         Boolean               @default(false) @map("is_approved")
  workflowConfigId   String?               @map("workflow_config_id")
  approvals          TicketApproval[]
  ticket_attachments ticket_attachments[]
  comments           TicketComment[]
  ticket_logs        ticket_logs[]
  itAsset            ITAsset?              @relation(fields: [assetId], references: [id])
  assignee           Employee?             @relation("TicketAssignee", fields: [assigneeId], references: [id])
  category           TicketCategory        @relation(fields: [categoryId], references: [id])
  requester          Employee              @relation("TicketRequester", fields: [requesterId], references: [id])
  workflowConfig     TicketWorkflowConfig? @relation("TicketToWorkflowConfig", fields: [workflowConfigId], references: [id])

  @@index([categoryId])
  @@index([status])
  @@index([requesterId])
  @@index([assigneeId])
  @@index([deletedAt])
  @@index([deletedBatchId])
  @@map("tickets")
}

model TicketWorkflowConfig {
  id           String               @id @default(uuid())
  name         String
  description  String?
  isActive     Boolean              @default(true) @map("is_active")
  categoryId   String?              @map("category_id")
  departmentId String?              @map("department_id")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  steps        TicketWorkflowStep[]
  tickets      Ticket[]             @relation("TicketToWorkflowConfig")

  @@map("ticket_workflow_configs")
}

model TicketWorkflowStep {
  id               String               @id @default(uuid())
  workflowConfigId String               @map("workflow_config_id")
  order            Int
  name             String
  approverType     TicketApproverType   @map("approver_type")
  approverId       String?              @map("approver_id")
  approvals        TicketApproval[]
  workflowConfig   TicketWorkflowConfig @relation(fields: [workflowConfigId], references: [id], onDelete: Cascade)

