  projectId  String      @map("project_id")
  employeeId String      @map("employee_id")
  role       ProjectRole @default(MEMBER)
  joinedAt   DateTime    @default(now()) @map("joined_at")
  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, employeeId])
  @@map("project_members")
}

model ProjectTask {
  id             String           @id @default(uuid())
  projectId      String           @map("project_id")
  parentId       String?          @map("parent_id")
  title          String
  description    String?
  startDate      DateTime?        @map("start_date")
  dueDate        DateTime?        @map("due_date")
  duration       Int?
  progress       Int              @default(0)
  status         TaskStatus       @default(TODO)
  priority       TaskPriority     @default(MEDIUM)
  assigneeId     String?          @map("assignee_id")
  position       Int              @default(0)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")
  deletedBatchId String?          @map("deleted_batch_id")
  deletedById    String?          @map("deleted_by_id")
  assignee       Employee?        @relation(fields: [assigneeId], references: [id])
  parent         ProjectTask?     @relation("TaskHierarchy", fields: [parentId], references: [id])
  children       ProjectTask[]    @relation("TaskHierarchy")
  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  successors     TaskDependency[] @relation("TaskPredecessor")
  predecessors   TaskDependency[] @relation("TaskSuccessor")

  @@index([projectId])
  @@index([deletedAt])
  @@index([deletedBatchId])
  @@map("project_tasks")
}

model TaskDependency {
  id            String         @id @default(uuid())
  predecessorId String         @map("predecessor_id")
  successorId   String         @map("successor_id")
  type          DependencyType @default(FINISH_TO_START)
  predecessor   ProjectTask    @relation("TaskPredecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
  successor     ProjectTask    @relation("TaskSuccessor", fields: [successorId], references: [id], onDelete: Cascade)

  @@unique([predecessorId, successorId])
  @@map("task_dependencies")
}

model MealSession {
  id               String             @id @default(uuid())
  name             String
  code             MealSessionCode    @unique
  timeStart        String             @map("time_start")
  timeEnd          String             @map("time_end")
  cutoffTime       String             @map("cutoff_time")
  isActive         Boolean            @default(true) @map("is_active")
  maxRegistrations Int?               @map("max_registrations")
  defaultPrice     Int                @default(0) @map("default_price")
  sortOrder        Int                @default(0) @map("sort_order")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  menus            MealMenu[]
  registrations    MealRegistration[]

  @@map("meal_sessions")
}

model MealRegistration {
  id             String        @id @default(uuid())
  employeeId     String        @map("employee_id")
  sessionId      String        @map("session_id")
  date           DateTime      @db.Date
  status         MealRegStatus @default(REGISTERED)
  registeredAt   DateTime      @default(now()) @map("registered_at")
  cancelledAt    DateTime?     @map("cancelled_at")
  usedAt         DateTime?     @map("used_at")
