generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(uuid())
  username                String                   @unique
  email                   String                   @unique
  passwordHash            String?                  @map("password_hash")
  status                  UserStatus               @default(ACTIVE)
  lastLoginAt             DateTime?                @map("last_login_at")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  createdById             String?                  @map("created_by_id")
  deletedAt               DateTime?                @map("deleted_at")
  deletedBatchId          String?                  @map("deleted_batch_id")
  deletedById             String?                  @map("deleted_by_id")
  updatedById             String?                  @map("updated_by_id")
  auditLogs               AuditLog[]
  createdCompanies        Company[]                @relation("CompanyCreatedBy")
  deletedCompanies        Company[]                @relation("CompanyDeletedBy")
  updatedCompanies        Company[]                @relation("CompanyUpdatedBy")
  createdDepartments      Department[]             @relation("DepartmentCreator")
  deletedDepartments      Department[]             @relation("DepartmentDeleter")
  updatedDepartments      Department[]             @relation("DepartmentUpdater")
  createdDivisions        Division[]               @relation("DivisionCreatedBy")
  deletedDivisions        Division[]               @relation("DivisionDeletedBy")
  updatedDivisions        Division[]               @relation("DivisionUpdatedBy")
  employeesCreated        Employee[]               @relation("EmployeeCreatedBy")
  employeesDeleted        Employee[]               @relation("EmployeeDeletedBy")
  employeesUpdated        Employee[]               @relation("EmployeeUpdatedBy")
  employee                Employee?
  createdFactories        Factory[]                @relation("FactoryCreator")
  deletedFactories        Factory[]                @relation("FactoryDeleter")
  updatedFactories        Factory[]                @relation("FactoryUpdater")
  uploadedFiles           File[]
  importHistory           ImportHistory[]
  jobTitlesCreated        JobTitle[]               @relation("JobTitleCreatedBy")
  jobTitlesDeleted        JobTitle[]               @relation("JobTitleDeletedBy")
  jobTitlesUpdated        JobTitle[]               @relation("JobTitleUpdatedBy")
  jobPositionsCreated     JobPosition[]            @relation("JobPositionCreatedBy")
  jobPositionsDeleted     JobPosition[]            @relation("JobPositionDeletedBy")
  jobPositionsUpdated     JobPosition[]            @relation("JobPositionUpdatedBy")
  moduleVisibilityConfigs ModuleVisibilityConfig[] @relation("VisibilityGlobal")
  updatedOrgConfigs       OrgChartConfig[]         @relation("OrgConfigUpdater")
  createdOrgOverrides     OrgChartOverride[]       @relation("UserOrgOverrideCreator")
  createdOrgChartVersions OrgChartVersion[]        @relation("OrgChartVersionCreator")
  updatedOrgOverrides     OrgChartViewOverride[]
  createdSections         Section[]                @relation("SectionCreatedBy")
  deletedSections         Section[]                @relation("SectionDeletedBy")
  updatedSections         Section[]                @relation("SectionUpdatedBy")
  createdColumnConfigs    TableColumnConfig[]      @relation("ConfigCreatedBy")
  updatedColumnConfigs    TableColumnConfig[]      @relation("ConfigUpdatedBy")
  trashRetentionConfigs   TrashRetentionConfig[]   @relation("TrashConfigUpdater")
  permissions             UserPermission[]
  roles                   UserRole[]
  createdBy               User?                    @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers            User[]                   @relation("UserCreator")
  deletedByUser           User?                    @relation("UserDeleter", fields: [deletedById], references: [id])
  deletedUsers            User[]                   @relation("UserDeleter")
  updatedBy               User?                    @relation("UserUpdater", fields: [updatedById], references: [id])
  updatedUsers            User[]                   @relation("UserUpdater")
  categoriesCreated       Category[]               @relation("CategoryCreatedBy")
  categoriesUpdated       Category[]               @relation("CategoryUpdatedBy")
  locationsCreated        Location[]               @relation("LocationCreatedBy")
  locationsUpdated        Location[]               @relation("LocationUpdatedBy")

  @@index([deletedAt])
  @@index([deletedBatchId])
  @@map("users")
}

model ModuleVisibilityConfig {
  id          String               @id @default(uuid())
  moduleCode  String               @map("module_code")
  targetType  VisibilityTargetType @map("target_type")
  targetId    String?              @map("target_id")
  isVisible   Boolean              @default(true) @map("is_visible")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  updatedById String?              @map("updated_by_id")
  name        String?              @map("name")
  updatedBy   User?                @relation("VisibilityGlobal", fields: [updatedById], references: [id])

  @@unique([moduleCode, targetType, targetId])
  @@index([targetType, targetId])
  @@map("module_visibility_configs")
}

model Role {
  id             String           @id @default(uuid())
  code           String           @unique
  name           String
  description    String?
  createdAt      DateTime         @default(now()) @map("created_at")
  deletedAt      DateTime?        @map("deleted_at")
  deletedBatchId String?          @map("deleted_batch_id")
  deletedById    String?          @map("deleted_by_id")
  permissions    RolePermission[]
  users          UserRole[]

  @@index([deletedAt])
  @@index([deletedBatchId])
  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  code        String           @unique
  description String?
  module      String?
  createdAt   DateTime         @default(now()) @map("created_at")
  roles       RolePermission[]
  users       UserPermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model UserPermission {
  userId       String     @map("user_id")
  permissionId String     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
}

model OrgChartConfig {
  id          String   @id
  nodesep     Int      @default(50)
  ranksep     Int      @default(120)
  zoom        Float    @default(0.85)
  nodeDims    Json?    @map("node_dims")
  nodeColors  Json?    @map("node_colors")
  nodeLevels  Json?    @map("node_levels")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedById String?  @map("updated_by_id")
  updatedBy   User?    @relation("OrgConfigUpdater", fields: [updatedById], references: [id])

  @@map("org_chart_configs")
}

model OrgChartViewOverride {
  id            String   @id @default(uuid())
  chartKey      String   @unique @map("chart_key")
  hiddenNodeIds Json     @default("[]") @map("hidden_node_ids")
  customEdges   Json     @default("[]") @map("custom_edges")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  updatedById   String?  @map("updated_by_id")
  updatedBy     User?    @relation(fields: [updatedById], references: [id])

  @@map("org_chart_view_overrides")
}

model OrgChartOverride {
  id              String   @id @default(uuid())
  employeeId      String   @map("employee_id")
  action          String
  targetManagerId String   @map("target_manager_id")
  targetHandle    String?  @map("target_handle")
  createdAt       DateTime @default(now()) @map("created_at")
  createdById     String?  @map("created_by")
  createdBy       User?    @relation("UserOrgOverrideCreator", fields: [createdById], references: [id])
  employee        Employee @relation("EmployeeOverride", fields: [employeeId], references: [id], onDelete: Cascade)
  targetManager   Employee @relation("TargetManagerOverride", fields: [targetManagerId], references: [id])

  @@index([employeeId])
  @@map("org_chart_overrides")
}

model OrgChartVersion {
  id          String   @id @default(uuid())
  chartKey    String   @map("chart_key")
  versionNum  Int      @map("version_num")
  label       String?
  description String?
  isScenario  Boolean  @default(false) @map("is_scenario")
  snapshot    Json
  createdAt   DateTime @default(now()) @map("created_at")
  createdById String?  @map("created_by_id")
  createdBy   User?    @relation("OrgChartVersionCreator", fields: [createdById], references: [id])

  @@unique([chartKey, versionNum])
  @@index([chartKey, isScenario])
  @@index([createdAt])
  @@map("org_chart_versions")
}

model AuditLog {
  id           String      @id @default(uuid())
  actorUserId  String?     @map("actor_user_id")
  action       AuditAction
  entityType   String      @map("entity_type")
  entityId     String      @map("entity_id")
  beforeJson   Json?       @map("before_json")
  afterJson    Json?       @map("after_json")
  ip           String?
  userAgent    String?     @map("user_agent")
  computerName String?     @map("computer_name")
  createdAt    DateTime    @default(now()) @map("created_at")
  actor        User?       @relation(fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("audit_logs")
}

model File {
  id                 String               @id @default(uuid())
  storagePath        String               @map("storage_path")
  originalName       String               @map("original_name")
  mimeType           String               @map("mime_type")
  size               Int
  checksum           String?
  uploadedById       String               @map("uploaded_by")
  linkedEntityType   String?              @map("linked_entity_type")
  linkedEntityId     String?              @map("linked_entity_id")
  createdAt          DateTime             @default(now()) @map("created_at")
  deletedAt          DateTime?            @map("deleted_at")
  deletedBatchId     String?              @map("deleted_batch_id")
  deletedById        String?              @map("deleted_by_id")
  uploadedBy         User                 @relation(fields: [uploadedById], references: [id])
  ticket_attachments ticket_attachments[]

  @@index([linkedEntityType, linkedEntityId])
  @@index([deletedAt])
  @@index([deletedBatchId])
  @@map("files")
}

model Factory {
  id                 String        @id @default(uuid())
  code               String        @unique
  name               String
  address            String?
  status             FactoryStatus @default(ACTIVE)
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  deletedAt          DateTime?     @map("deleted_at")
  deletedById        String?       @map("deleted_by_id")
  deletedBatchId     String?       @map("deleted_batch_id")
  createdById        String?       @map("created_by")
  updatedById        String?       @map("updated_by")
  companyId          String?       @map("company_id")
  excludeFromFilters Boolean       @default(false) @map("exclude_from_filters")
  managerEmployeeId  String?       @map("manager_employee_id")
  showOnOrgChart     Boolean       @default(false) @map("show_on_org_chart")
  uiPositionX        Float?        @map("ui_position_x")
  uiPositionY        Float?        @map("ui_position_y")
  divisions          Division[]
  employees          Employee[]
  company            Company?      @relation(fields: [companyId], references: [id])
  createdBy          User?         @relation("FactoryCreator", fields: [createdById], references: [id])
  deletedBy          User?         @relation("FactoryDeleter", fields: [deletedById], references: [id])
  manager            Employee?     @relation("FactoryManager", fields: [managerEmployeeId], references: [id])
  updatedBy          User?         @relation("FactoryUpdater", fields: [updatedById], references: [id])

  @@index([companyId])
  @@index([deletedAt])
  @@index([deletedBatchId])
  @@map("factories")
}

model Department {
  id                 String               @id @default(uuid())
  code               String               @unique
  name               String
  managerEmployeeId  String?              @map("manager_employee_id")
  status             DepartmentStatus     @default(ACTIVE)
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  createdById        String?              @map("created_by")
  updatedById        String?              @map("updated_by")
  deletedAt          DateTime?            @map("deleted_at")
  deletedBatchId     String?              @map("deleted_batch_id")
  deletedById        String?              @map("deleted_by_id")
  note               String?
  divisionId         String?              @map("division_id")
  companyId          String?              @map("company_id")
  excludeFromFilters Boolean              @default(false) @map("exclude_from_filters")
  showOnOrgChart            Boolean              @default(false) @map("show_on_org_chart")
  useManagerDisplayTitle    Boolean              @default(false) @map("use_manager_display_title")
  managerDisplayTitle       String?              @map("manager_display_title")
  uiPositionX               Float?               @map("ui_position_x")
  uiPositionY               Float?               @map("ui_position_y")
  company            Company?             @relation(fields: [companyId], references: [id])
  createdBy          User?                @relation("DepartmentCreator", fields: [createdById], references: [id])
  deletedBy          User?                @relation("DepartmentDeleter", fields: [deletedById], references: [id])
  division           Division?            @relation(fields: [divisionId], references: [id])
  manager            Employee?            @relation("DepartmentManager", fields: [managerEmployeeId], references: [id])
  updatedBy          User?                @relation("DepartmentUpdater", fields: [updatedById], references: [id])
  jobHistoryFrom     EmployeeJobHistory[] @relation("HistoryFromDept")
  jobHistoryTo       EmployeeJobHistory[] @relation("HistoryToDept")
  employees          Employee[]           @relation("EmployeeDepartment")
  itAssets           ITAsset[]
  sections           Section[]
  positions          Position[]           @relation("PositionDepartment")

  @@index([divisionId])
  @@index([deletedAt])
  @@index([deletedBatchId])
  @@map("departments")
}

model Company {
  id                 String           @id @default(uuid())
  code               String           @unique
  name               String
  address            String?
  note               String?
  status             DepartmentStatus @default(ACTIVE)
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  deletedAt          DateTime?        @map("deleted_at")
  deletedById        String?          @map("deleted_by_id")
  deletedBatchId     String?          @map("deleted_batch_id")
  createdById        String?          @map("created_by_id")
  updatedById        String?          @map("updated_by_id")
  excludeFromFilters Boolean          @default(false) @map("exclude_from_filters")
  managerEmployeeId  String?          @map("manager_employee_id")
  showOnOrgChart     Boolean          @default(false) @map("show_on_org_chart")
  uiPositionX        Float?           @map("ui_position_x")
  uiPositionY        Float?           @map("ui_position_y")
  createdBy          User?            @relation("CompanyCreatedBy", fields: [createdById], references: [id])
  deletedBy          User?            @relation("CompanyDeletedBy", fields: [deletedById], references: [id])
  manager            Employee?        @relation("CompanyManager", fields: [managerEmployeeId], references: [id])
  updatedBy          User?            @relation("CompanyUpdatedBy", fields: [updatedById], references: [id])
  departments        Department[]
  divisions          Division[]
  employees          Employee[]       @relation("EmployeeCompany")
  factories          Factory[]
  sections           Section[]

  @@index([deletedAt])
  @@index([deletedBatchId])
  @@map("companies")
}

model Division {
  id                 String           @id @default(uuid())
  code               String           @unique
  name               String
  factoryId          String?          @map("factory_id")
  note               String?
  status             DepartmentStatus @default(ACTIVE)
  managerEmployeeId  String?          @map("manager_employee_id")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  deletedAt          DateTime?        @map("deleted_at")
  deletedById        String?          @map("deleted_by_id")
  deletedBatchId     String?          @map("deleted_batch_id")
  createdById        String?          @map("created_by_id")
  updatedById        String?          @map("updated_by_id")
  companyId          String?          @map("company_id")
  excludeFromFilters Boolean          @default(false) @map("exclude_from_filters")
  showOnOrgChart            Boolean          @default(false) @map("show_on_org_chart")
  useManagerDisplayTitle    Boolean          @default(false) @map("use_manager_display_title")
  managerDisplayTitle       String?          @map("manager_display_title")
  uiPositionX               Float?           @map("ui_position_x")
  uiPositionY               Float?           @map("ui_position_y")
  departments        Department[]
  company            Company?         @relation(fields: [companyId], references: [id])
  createdBy          User?            @relation("DivisionCreatedBy", fields: [createdById], references: [id])
  deletedBy          User?            @relation("DivisionDeletedBy", fields: [deletedById], references: [id])
  factory            Factory?         @relation(fields: [factoryId], references: [id])
  manager            Employee?        @relation("DivisionManager", fields: [managerEmployeeId], references: [id])
  updatedBy          User?            @relation("DivisionUpdatedBy", fields: [updatedById], references: [id])
  employees          Employee[]       @relation("EmployeeDivision")

  @@index([factoryId])
  @@index([deletedAt])
  @@index([deletedBatchId])
  @@map("divisions")
}

model Section {
  id                 String           @id @default(uuid())
  code               String           @unique
  name               String
  departmentId       String?          @map("department_id")
  note               String?
  status             DepartmentStatus @default(ACTIVE)
  managerEmployeeId  String?          @map("manager_employee_id")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  deletedAt          DateTime?        @map("deleted_at")
  deletedById        String?          @map("deleted_by_id")
  deletedBatchId     String?          @map("deleted_batch_id")
  createdById        String?          @map("created_by_id")
  updatedById        String?          @map("updated_by_id")
  companyId          String?          @map("company_id")
  excludeFromFilters Boolean          @default(false) @map("exclude_from_filters")
  showOnOrgChart            Boolean          @default(false) @map("show_on_org_chart")
  useManagerDisplayTitle    Boolean          @default(false) @map("use_manager_display_title")
  managerDisplayTitle       String?          @map("manager_display_title")
  uiPositionX               Float?           @map("ui_position_x")
  uiPositionY               Float?           @map("ui_position_y")
  employees          Employee[]       @relation("EmployeeSection")
  company            Company?         @relation(fields: [companyId], references: [id])
  createdBy          User?            @relation("SectionCreatedBy", fields: [createdById], references: [id])
  deletedBy          User?            @relation("SectionDeletedBy", fields: [deletedById], references: [id])
  department         Department?      @relation(fields: [departmentId], references: [id])
  manager            Employee?        @relation("SectionManager", fields: [managerEmployeeId], references: [id])
  updatedBy          User?            @relation("SectionUpdatedBy", fields: [updatedById], references: [id])
  positions          Position[]       @relation("PositionSection")

  @@index([departmentId])
  @@index([deletedAt])
  @@index([deletedBatchId])
  @@map("sections")
}

model JobTitle {
  id              String               @id @default(uuid())
  code            String               @unique
  name            String
  description     String?
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  createdById     String?              @map("created_by_id")
  deletedAt       DateTime?            @map("deleted_at")
  deletedBatchId  String?              @map("deleted_batch_id")
  deletedById     String?              @map("deleted_by_id")
  status          JobTitleStatus       @default(ACTIVE)
  updatedById     String?              @map("updated_by_id")
  jobHistoryFrom  EmployeeJobHistory[] @relation("HistoryFromJob")
  jobHistoryTo    EmployeeJobHistory[] @relation("HistoryToJob")
  employees       Employee[]
  jobDescriptions JobDescription[]
  createdBy       User?                @relation("JobTitleCreatedBy", fields: [createdById], references: [id])
  deletedBy       User?                @relation("JobTitleDeletedBy", fields: [deletedById], references: [id])
  updatedBy       User?                @relation("JobTitleUpdatedBy", fields: [updatedById], references: [id])

  @@index([deletedAt])
  @@index([deletedBatchId])
  @@map("job_titles")
}

model JobPosition {
  id             String            @id @default(uuid())
  code           String            @unique
  name           String
  description    String?
  status         JobTitleStatus    @default(ACTIVE)
  departmentId   String?           @map("department_id")
  jobTitleId     String?           @map("job_title_id")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  createdById    String?           @map("created_by_id")
  updatedById    String?           @map("updated_by_id")
  deletedAt      DateTime?         @map("deleted_at")
  deletedBatchId String?           @map("deleted_batch_id")
  deletedById    String?           @map("deleted_by_id")
  showOnOrgChart Boolean           @default(false) @map("show_on_org_chart")
  uiPositionX    Float?            @map("ui_position_x")
  uiPositionY    Float?            @map("ui_position_y")
  createdBy      User?             @relation("JobPositionCreatedBy", fields: [createdById], references: [id])
  updatedBy      User?             @relation("JobPositionUpdatedBy", fields: [updatedById], references: [id])
  deletedBy      User?             @relation("JobPositionDeletedBy", fields: [deletedById], references: [id])

  @@index([deletedAt])
  @@index([departmentId])
  @@map("job_positions")
}

model Employee {
  id                   String               @id @default(uuid())
  employeeCode         String               @unique @map("employee_code")
  userId               String?              @unique @map("user_id")
  fullName             String               @map("full_name")
  orgLevel             String?              @map("org_level")
  dob                  DateTime?
  phone                String?
  emailCompany         String?              @map("email_company")
  avatar               String?
  departmentId         String?              @map("department_id")
  jobTitleId           String?              @map("job_title_id")
  managerEmployeeId    String?              @map("manager_employee_id")
  employmentStatus     EmploymentStatus     @default(PROBATION) @map("employment_status")
  joinedAt             DateTime?            @map("joined_at")
  resignedAt           DateTime?            @map("resigned_at")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  nationalId           String?              @map("national_id")
  placeOfIssue         String?              @map("place_of_issue")
  dateOfIssue          DateTime?            @map("date_of_issue")
  gender               Gender?
  permanentAddress     String?              @map("permanent_address")
  temporaryAddress     String?              @map("temporary_address")
  birthPlace           String?              @map("birth_place")
  ethnicity            String?
  religion             String?
  personalEmail        String?              @map("personal_email")
  bankName             String?              @map("bank_name")
  bankBranch           String?              @map("bank_branch")
  bankAccountNo        String?              @map("bank_account_no")
  socialInsuranceNo    String?              @map("social_insurance_no")
  healthInsuranceNo    String?              @map("health_insurance_no")
  taxCode              String?              @map("tax_code")
  contractType         ContractType?        @map("contract_type")
  contractStartDate    DateTime?            @map("contract_start_date")
  contractEndDate      DateTime?            @map("contract_end_date")
  education            EducationLevel?
  major                String?
  school               String?
  graduationYear       Int?                 @map("graduation_year")
  accessCardId         String?              @map("access_card_id")
  accessCardStatus     String?              @map("access_card_status")
  age                  Int?
  contractNumber       String?              @map("contract_number")
  createdById          String?              @map("created_by_id")
  deletedAt            DateTime?            @map("deleted_at")
  deletedBatchId       String?              @map("deleted_batch_id")
  deletedById          String?              @map("deleted_by_id")
  divisionId           String?              @map("division_id")
  documentFile         String?              @map("document_file")
  emergencyContactName String?              @map("emergency_contact_name")
  emergencyPhone       String?              @map("emergency_phone")
  factoryId            String?              @map("factory_id")
  maritalStatus        MaritalStatus?       @map("marital_status")
  note                 String?
  recordCode           String?              @map("record_code")
  referrer             String?              @map("referrer")
  salaryLevel          String?              @map("salary_level")
  sectionId            String?              @map("section_id")
  shoeSize             String?              @map("shoe_size")
  uniformPantsSize     String?              @map("uniform_pants_size")
  uniformShirtSize     String?              @map("uniform_shirt_size")
  updatedById          String?              @map("updated_by_id")
  companyId            String?              @map("company_id")
  showOnOrgChart       Boolean              @default(false) @map("show_on_org_chart")
  uiPositionX          Float?               @map("ui_position_x")
  uiPositionY          Float?               @map("ui_position_y")
  positionId           String?              @map("position_id")
  assetAssignments     AssetAssignment[]
  bookingAttendees     BookingAttendee[]
  managedCompanies     Company[]            @relation("CompanyManager")
  managedDepartments   Department[]         @relation("DepartmentManager")
  managedDivisions     Division[]           @relation("DivisionManager")
  contracts            EmployeeContract[]
  familyMembers        EmployeeFamily[]
  jobHistory           EmployeeJobHistory[]
