  targetId    String?  @map("target_id")
  createdById String   @map("created_by_id")
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   User     @relation("ConfigCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?    @relation("ConfigUpdatedBy", fields: [updatedById], references: [id])

  @@unique([moduleKey, applyTo, targetId])
  @@index([moduleKey])
  @@map("table_column_configs")
}

model ImportHistory {
  id         String       @id @default(uuid())
  moduleKey  String       @map("module_key")
  moduleType String?      @map("module_type")
  fileName   String       @map("file_name")
