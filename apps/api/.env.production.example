# =============================================================
# eOffice Production Environment Template
# Copy this file and rename to .env for production deployment
# =============================================================

# Database - PostgreSQL
# connection_limit=30: Cho phep 30 connections dong thoi (du cho 500 users)
# pool_timeout=30: Timeout 30s cho connection pool
DATABASE_URL=postgresql://eoffice_user:STRONG_PASSWORD_HERE@db-server:5432/eoffice_prod?connection_limit=30&pool_timeout=30

# Redis (khuyến nghị bật cho production)
REDIS_URL=redis://localhost:6379

# JWT - ĐỔI SECRET KEY CHO PRODUCTION!
JWT_SECRET=CHANGE_THIS_TO_64_CHAR_RANDOM_STRING

# API
PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://eoffice.your-domain.com

# Logging
LOG_LEVEL=warn
